// Ready2Rent — Prisma schema
// Vacation rental turnover operations platform.
//
// Design notes:
// - The reservation/job model is provider-agnostic. iCal is the first ingestion
//   provider; direct APIs (Airbnb/Vrbo/Guesty/Hostaway/...) attach later WITHOUT
//   changing Reservation or TurnoverJob. `sourcePlatform` + `externalUid` are the
//   stable identity used for change detection regardless of provider.
// - History is never destroyed automatically. Reservations that vanish from a feed
//   are flagged POSSIBLY_CANCELED, not deleted. Jobs carry full status history.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; "rhel-openssl-3.0.x" for Netlify/AWS Lambda runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrganizationType {
  OWNER
  CLEANING_COMPANY
  LINEN_COMPANY
  ADMIN
}

/// Who operationally owns a property record. CLEANER_MANAGED = a cleaner added
/// the property from a calendar link the owner gave them; the owner is tracked
/// as a contact (PropertyOwnerContact) and notified by email, but has no account
/// until they claim it.
enum ManagementMode {
  OWNER_MANAGED
  CLEANER_MANAGED
}

enum MessageChannel {
  EMAIL
  SMS
}

enum MessageStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

/// Global role on a user account. An individual may belong to multiple orgs,
/// but their primary capability set is driven by this role.
enum UserRole {
  OWNER
  CLEANER
  LINEN
  ADMIN
}

/// Role of a user *within* a specific organization.
enum MemberRole {
  OWNER // org admin / account holder
  MANAGER
  MEMBER
}

enum CalendarPlatform {
  AIRBNB
  VRBO
  MANUAL
  OTHER
}

enum ReservationStatus {
  ACTIVE
  CHANGED
  POSSIBLY_CANCELED
  CANCELED
}

enum JobStatus {
  NEEDS_SCHEDULING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  PROBLEM
  CANCELED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Forward-compatible job kinds. Phase 1 only emits TURNOVER. Phase 2 linen
/// tasks (pickup/wash/delivery) reuse the same job machinery + history + photos.
enum JobType {
  TURNOVER
  LINEN_PICKUP
  LINEN_WASH
  LINEN_DELIVERY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum NotificationType {
  JOB_CREATED
  JOB_CHANGED
  JOB_COMPLETED
  JOB_CANCELED
  JOB_PROBLEM
  RESERVATION_CHANGED
  RESERVATION_CANCELED
  SAME_DAY_TURNOVER
  ASSIGNMENT
  JOB_STARTED
  SYNC_FAILED
}

// ---------------------------------------------------------------------------
// Identity & org membership
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  role         UserRole @default(OWNER)
  phone        String?
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships            OrganizationMember[]
  assignedJobs           TurnoverJob[]           @relation("JobAssignee")
  statusChanges          JobStatusHistory[]
  uploadedPhotos         JobPhoto[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  assignedProperties     Property[]              @relation("PropertyCleanerUser")
  createdProperties      Property[]              @relation("PropertyCreatedBy")
  serviceProviderProfile ServiceProviderProfile?
  invitesSent            Invitation[]            @relation("InvitesSent")
  invitesAccepted        Invitation[]            @relation("InvitesAccepted")
  createdPayments        Payment[]               @relation("PaymentCreatedBy")
  createdExpenses        Expense[]               @relation("ExpenseCreatedBy")

  @@index([role])
}

/// Connects hosts and cleaners. A host can invite a cleaner (or vice versa) by
/// email; accepting links the invitee to the property/org. Off-platform hosts
/// also have the lighter-weight PropertyOwnerContact claim flow; this is the
/// account-to-account version.
enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

model Invitation {
  id               String       @id @default(cuid())
  token            String       @unique @default(cuid())
  email            String
  /// Role the invitee will act as for this connection (OWNER = host, CLEANER).
  invitedRole      UserRole
  status           InviteStatus @default(PENDING)
  invitedByUserId  String
  /// Inviter's organization the invitee is linked to on accept.
  organizationId   String?
  /// Optional property to assign (cleaner) or grant host access to on accept.
  propertyId       String?
  acceptedByUserId String?
  acceptedAt       DateTime?
  createdAt        DateTime     @default(now())
  expiresAt        DateTime?

  invitedBy    User          @relation("InvitesSent", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy   User?         @relation("InvitesAccepted", fields: [acceptedByUserId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property?     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([status])
  @@index([propertyId])
}

/// Per-user in-app notification opt-outs. A missing row = everything on (the
/// default). Lets hosts mute categories so they aren't pinged on every event.
model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  newJobs         Boolean  @default(true)
  jobChanges      Boolean  @default(true)
  jobCompleted    Boolean  @default(true)
  jobCanceled     Boolean  @default(true)
  sameDayTurnover Boolean  @default(true)
  problems        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  members                OrganizationMember[]
  ownedProperties        Property[]              @relation("PropertyOwnerOrg")
  cleanerForProperties   Property[]              @relation("PropertyCleanerOrg")
  linenForProperties     Property[]              @relation("PropertyLinenOrg")
  assignedJobs           TurnoverJob[]           @relation("JobAssignedOrg")
  serviceProviderProfile ServiceProviderProfile?
  invitations            Invitation[]

  @@index([type])
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(MEMBER)
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Properties & calendar feeds
// ---------------------------------------------------------------------------

model Property {
  id                   String   @id @default(cuid())
  ownerOrganizationId  String
  name                 String
  address              String?
  city                 String?
  state                String?
  zip                  String?
  bedrooms             Int      @default(0)
  bathrooms            Int      @default(0)
  /// IANA timezone (e.g. "America/New_York"). Used to resolve checkout/checkin
  /// wall-clock times into absolute instants for turnover-window math.
  timezone             String   @default("America/New_York")
  /// Wall-clock "HH:mm" defaults applied when a feed event has no explicit time.
  defaultCheckInTime   String   @default("16:00")
  defaultCheckOutTime  String   @default("10:00")
  notes                String?
  /// Optional hero image for the property (Supabase Storage public URL).
  imageUrl             String?
  /// Hex color (e.g. "#3b82f6") used for this property's bars on the calendar.
  /// Null = fall back to a deterministic palette color.
  calendarColor        String?
  /// Default price (whole dollars) paid for one turnover clean of this property.
  /// Surfaced on the calendar and job cards. Null = no price set.
  cleaningPrice        Int?
  active               Boolean  @default(true)
  /// Owner-led vs cleaner-led onboarding (see ManagementMode).
  managementMode       ManagementMode @default(OWNER_MANAGED)
  createdByUserId      String?
  /// Stable token for the no-login public status page the owner-notification
  /// emails link to (/p/<publicToken>).
  publicToken          String?  @unique @default(cuid())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Assignment: a property can be serviced by a cleaning org and/or a specific
  // cleaner user, and (Phase 2) a linen org.
  assignedCleanerOrganizationId String?
  assignedCleanerUserId         String?
  linenProviderOrganizationId   String?

  ownerOrganization         Organization  @relation("PropertyOwnerOrg", fields: [ownerOrganizationId], references: [id], onDelete: Cascade)
  assignedCleanerOrganization Organization? @relation("PropertyCleanerOrg", fields: [assignedCleanerOrganizationId], references: [id])
  assignedCleanerUser       User?         @relation("PropertyCleanerUser", fields: [assignedCleanerUserId], references: [id])
  linenProviderOrganization Organization? @relation("PropertyLinenOrg", fields: [linenProviderOrganizationId], references: [id])
  createdByUser             User?         @relation("PropertyCreatedBy", fields: [createdByUserId], references: [id])

  calendarFeeds CalendarFeed[]
  reservations  Reservation[]
  turnoverJobs  TurnoverJob[]
  syncLogs      SyncLog[]
  ownerContact  PropertyOwnerContact?
  messageLogs   MessageLog[]
  checklistItems PropertyChecklistItem[]
  invitations   Invitation[]
  inventoryItems InventoryItem[]
  payments       Payment[]
  expenses       Expense[]

  @@index([ownerOrganizationId])
  @@index([assignedCleanerOrganizationId])
  @@index([assignedCleanerUserId])
  @@index([managementMode])
}

model CalendarFeed {
  id         String           @id @default(cuid())
  propertyId String
  platform   CalendarPlatform
  /// Feed URLs are SENSITIVE. Stored AES-256-GCM encrypted; never logged.
  feedUrlEncrypted String
  /// SHA-256 of the normalized URL, used to dedupe feeds without decrypting.
  feedUrlHash      String
  active     Boolean          @default(true)
  lastSyncedAt   DateTime?
  lastSyncStatus SyncStatus?
  lastSyncError  String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  syncLogs     SyncLog[]

  @@unique([propertyId, feedUrlHash])
  @@index([propertyId])
  @@index([active])
}

// ---------------------------------------------------------------------------
// Reservations (normalized, provider-agnostic)
// ---------------------------------------------------------------------------

model Reservation {
  id             String            @id @default(cuid())
  propertyId     String
  calendarFeedId String
  /// Stable identity from the provider (iCal UID, or API reservation id later).
  externalUid    String
  sourcePlatform CalendarPlatform
  summary        String?
  /// Resolved absolute instants (UTC) for the stay boundaries.
  checkInDate    DateTime
  checkOutDate   DateTime
  /// Exactly what the provider sent (for audit / re-normalization).
  rawStart       DateTime
  rawEnd         DateTime
  status         ReservationStatus @default(ACTIVE)
  lastSeenAt     DateTime          @default(now())
  /// Original provider payload (VEVENT fields, or API JSON).
  rawPayload     Json?

  // Richer fields — null for iCal-only sources, populated by PMS/API providers.
  guestName        String?
  guestCount       Int?
  confirmationCode String?
  guestPhoneLast4  String?
  reservationUrl   String?
  /// True when the provider gave real check-in/out times (vs property defaults).
  hasExactTimes    Boolean           @default(false)
  /// Soft duplicate detection across feeds (same property + overlapping dates).
  duplicateOfId  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  calendarFeed CalendarFeed @relation(fields: [calendarFeedId], references: [id], onDelete: Cascade)
  duplicateOf  Reservation? @relation("ReservationDuplicate", fields: [duplicateOfId], references: [id])
  duplicates   Reservation[] @relation("ReservationDuplicate")
  turnoverJob  TurnoverJob?

  @@unique([calendarFeedId, externalUid])
  @@index([propertyId])
  @@index([checkOutDate])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Turnover jobs (+ linen tasks in Phase 2 via JobType)
// ---------------------------------------------------------------------------

model TurnoverJob {
  id            String  @id @default(cuid())
  propertyId    String
  /// One turnover job per reservation. Linen sub-tasks (Phase 2) will hang off
  /// this via a parent relation (added later) but reuse the same status engine.
  reservationId String  @unique
  type          JobType @default(TURNOVER)

  assignedOrganizationId String?
  assignedUserId         String?

  checkoutDateTime    DateTime
  nextCheckInDateTime DateTime?
  /// True when a new guest checks in the same calendar day as checkout — the
  /// high-pressure "same-day turnover" cleaners must be warned about.
  sameDayTurnover     Boolean  @default(false)
  /// Minutes between checkout and next check-in (null = no known next stay).
  turnoverWindowMinutes Int?

  status   JobStatus   @default(NEEDS_SCHEDULING)
  priority JobPriority @default(NORMAL)
  /// Set when a host/cleaner manually completes or cancels a job. Locks the job
  /// against the sync's auto date-updates and CANCELED→reopen revival, so a
  /// deliberate override isn't undone on the next feed sync.
  manualStatusLock Boolean @default(false)

  ownerNotes   String?
  cleanerNotes String?
  /// Cleaner's description of a problem when the job is flagged PROBLEM. Shown to
  /// the host alongside any PROBLEM-kind photos.
  problemNote  String?

  completedAt DateTime?
  /// Set ~30 days after completion by the cleanup cron. Archived jobs drop off
  /// all dashboards/lists but the row is preserved (analytics are never lost);
  /// only their photos are pruned to reclaim storage.
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  property             Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation          Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  assignedOrganization Organization? @relation("JobAssignedOrg", fields: [assignedOrganizationId], references: [id])
  assignedUser         User?         @relation("JobAssignee", fields: [assignedUserId], references: [id])

  statusHistory   JobStatusHistory[]
  photos          JobPhoto[]
  notifications   Notification[]
  checklistChecks JobChecklistCheck[]
  payment         Payment?

  @@index([propertyId])
  @@index([assignedOrganizationId])
  @@index([assignedUserId])
  @@index([status])
  @@index([checkoutDateTime])
  @@index([completedAt])
  @@index([archivedAt])
  // Hot path: scope by assignee, filter by status, sort by checkout.
  @@index([assignedUserId, status, checkoutDateTime])
}

model JobStatusHistory {
  id              String     @id @default(cuid())
  jobId           String
  fromStatus      JobStatus?
  toStatus        JobStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime   @default(now())

  job           TurnoverJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  changedByUser User?       @relation(fields: [changedByUserId], references: [id])

  @@index([jobId])
}

/// Whether a job photo documents a finished clean or evidence of a problem.
enum PhotoKind {
  COMPLETION
  PROBLEM
}

model JobPhoto {
  id               String    @id @default(cuid())
  jobId            String
  url              String
  caption          String?
  kind             PhotoKind @default(COMPLETION)
  uploadedByUserId String?
  createdAt        DateTime  @default(now())

  job            TurnoverJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedByUser User?       @relation(fields: [uploadedByUserId], references: [id])

  @@index([jobId])
  @@index([jobId, kind])
}

/// A single line on a property's cleaning checklist, authored by the host. Order
/// is host-controlled via `position`. Checklists let hosts encode exactly how a
/// property should be turned over (staging, supplies, quirks).
model PropertyChecklistItem {
  id         String   @id @default(cuid())
  propertyId String
  text       String
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  checks   JobChecklistCheck[]

  @@index([propertyId, position])
}

/// Per-job completion state for a property checklist item. A row exists only when
/// the item is checked off for that job; deleting it un-checks. The property
/// template stays the source of truth for which items exist.
model JobChecklistCheck {
  id              String   @id @default(cuid())
  jobId           String
  itemId          String
  checkedByUserId String?
  checkedAt       DateTime @default(now())

  job  TurnoverJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  item PropertyChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([jobId, itemId])
  @@index([jobId])
}

// ---------------------------------------------------------------------------
// Inventory (cleaning supplies + linens, per property)
// ---------------------------------------------------------------------------

enum InventoryCategory {
  SUPPLY
  LINEN
}

/// Stock a property needs on hand: cleaning supplies (soap, paper) and linens
/// (towels, sheets, pillowcases) tracked by size. Hosts and the assigned cleaner
/// can both create and adjust items. `parLevel` marks the desired level; below it
/// the item reads as low.
model InventoryItem {
  id         String            @id @default(cuid())
  propertyId String
  category   InventoryCategory @default(SUPPLY)
  name       String
  /// Linen size, e.g. "Queen", "King", "Bath", "Hand", "Standard". Null for supplies.
  size       String?
  /// Counting unit, e.g. "rolls", "bottles", "sets", "pcs".
  unit       String?
  quantity   Int               @default(0)
  /// Desired on-hand level; quantity below this flags the item as low. Null = untracked.
  parLevel   Int?
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, category])
}

// ---------------------------------------------------------------------------
// Notifications & sync observability
// ---------------------------------------------------------------------------

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String?
  jobId      String?
  propertyId String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  TurnoverJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, read])
}

model SyncLog {
  id             String     @id @default(cuid())
  calendarFeedId String?
  propertyId     String?
  status         SyncStatus
  message        String?
  reservationsFound Int     @default(0)
  created        Int        @default(0)
  updated        Int        @default(0)
  canceled       Int        @default(0)
  jobsCreated    Int        @default(0)
  jobsUpdated    Int        @default(0)
  durationMs     Int?
  /// Failure detail. NEVER contains the raw feed URL (only host, if anything).
  errorDetail    String?
  startedAt      DateTime   @default(now())
  finishedAt     DateTime?

  calendarFeed CalendarFeed? @relation(fields: [calendarFeedId], references: [id], onDelete: SetNull)
  property     Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([calendarFeedId])
  @@index([propertyId])
  @@index([status])
  @@index([startedAt])
}

// ---------------------------------------------------------------------------
// Off-platform owner contact (cleaner-led model) + outbound message log
// ---------------------------------------------------------------------------

/// The real property owner when a cleaner added the property. No user account —
/// just who to notify (email v1, SMS later) and a token to claim the property
/// and convert into a platform owner.
model PropertyOwnerContact {
  id              String    @id @default(cuid())
  propertyId      String    @unique
  name            String?
  email           String?
  phone           String?
  notifyByEmail   Boolean   @default(true)
  notifyBySms     Boolean   @default(false)
  unsubscribed    Boolean   @default(false)
  claimToken      String    @unique @default(cuid())
  claimedByUserId String?
  claimedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

/// Audit log of outbound owner notifications (email v1). Mirrors SyncLog
/// discipline: every send recorded with status, for idempotency + debugging.
model MessageLog {
  id             String         @id @default(cuid())
  propertyId     String?
  jobId          String?
  ownerContactId String?
  channel        MessageChannel
  type           String
  toAddress      String
  subject        String?
  status         MessageStatus  @default(QUEUED)
  providerId     String?
  error          String?
  createdAt      DateTime       @default(now())

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Service provider profiles (Phase 3 marketplace — modeled now)
// ---------------------------------------------------------------------------

model ServiceProviderProfile {
  id             String   @id @default(cuid())
  organizationId String?  @unique
  userId         String?  @unique
  displayName    String
  bio            String?
  serviceAreas   String[] @default([])
  basePrice      Decimal? @db.Decimal(10, 2)
  ratingAvg      Float    @default(0)
  ratingCount    Int      @default(0)
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Financials — manual payment tracking + per-property expenses.
// Amounts are whole dollars (Int), matching Property.cleaningPrice. Stripe and
// other automated methods can be added to PaymentMethod later.
// ---------------------------------------------------------------------------

/// How a cleaning payment was (or will be) settled. P2P methods for now.
enum PaymentMethod {
  APPLE_PAY
  VENMO
  CASH_APP
  ZELLE
  CASH
  OTHER
}

enum PaymentStatus {
  DUE
  PAID
  CANCELED
}

enum ExpenseCategory {
  SUPPLIES
  REPAIRS
  UTILITIES
  CLEANING
  FEES
  OTHER
}

/// A cleaning payment owed by a host to a cleaner for a turnover. Auto-created
/// (status DUE, amount = property cleaning price) when a job is completed, and
/// also creatable/editable by hand. One payment per turnover job.
model Payment {
  id              String         @id @default(cuid())
  propertyId      String
  jobId           String?        @unique
  amount          Int
  method          PaymentMethod?
  status          PaymentStatus  @default(DUE)
  dueDate         DateTime?
  paidAt          DateTime?
  /// Free-text reference: Venmo handle, Zelle memo, confirmation code, etc.
  reference       String?
  note            String?
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  property      Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  job           TurnoverJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdByUser User?        @relation("PaymentCreatedBy", fields: [createdByUserId], references: [id])

  @@index([propertyId, status])
  @@index([status, dueDate])
}

/// A per-property expense with an optional uploaded receipt.
model Expense {
  id              String          @id @default(cuid())
  propertyId      String
  amount          Int
  category        ExpenseCategory @default(OTHER)
  description     String
  vendor          String?
  incurredAt      DateTime        @default(now())
  receiptUrl      String?
  createdByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdByUser User?    @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id])

  @@index([propertyId, incurredAt])
}
